BOT_TOKEN=npx -y @21st-dev/cli@latest install cursor --api-key "fe5d671ceeba5788ebfc6d4fddaac13500183a444fad8df65571e8a0d97069fa"

# Docker compose defaults:
DATABASE_URL=postgresql+asyncpg://serviceindriver:serviceindriver@db:5432/serviceindriver
REDIS_URL=redis://redis:6379/0

# Admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Feature toggles
SENTRY_DSN=
BOT_LONG_POLLING=true

# Limits from TZ (MVP defaults)
LIMIT_CUSTOMER_ORDERS_PER_DAY=10
LIMIT_WORKER_BIDS_PER_DAY=30

# Currency
DEFAULT_CURRENCY=RUB
MIN_PRICE=100
MAX_PRICE=500000

# Simplified geo (MVP)
SAME_CITY_ONLY=true

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
