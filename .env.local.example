# Скопируйте в .env.local:  copy .env.local.example .env.local
# Для локального Supabase (Docker) используйте URL и anon key из вывода: npx supabase status
# Ниже — стандартные значения демо-ключа локального Supabase (подходят сразу после `supabase start`).

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# Альтернатива (если вы храните ключ под таким именем):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Опционально: канонический URL (на Vercel в Dashboard или для кастомного домена), иначе берётся VERCEL_URL
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Опционально: видео на главной странице — ссылка на YouTube (полный URL) или прямой URL файла MP4/WebM
# Если не задано: сначала берётся public/videos/presentation.mp4, иначе короткий демо-ролик для проверки плеера
# NEXT_PUBLIC_PRESENTATION_VIDEO_URL=https://www.youtube.com/watch?v=XXXXXXXXXXX
